# Supabase Configuration
# VITE_SUPABASE_URL: Ambil dari Supabase > Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# SUPABASE_SERVICE_ROLE_KEY: Ambil dari Supabase > Settings > API > Secret Keys (service_role)
# PENTING: Gunakan 'service_role', bukan 'anon public'
SUPABASE_SERVICE_ROLE_KEY=ey... (secret key anda)
